<Window x:Class="CyberPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberPlayer"
        mc:Ignorable="d"
        FontFamily="Impact"
        Title="MainWindow" Height="450" Width="800" Name="VentanaPrincipal">

    <Grid Background="#0A0A0A">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="75"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,5,15,20">
            <TextBlock Text="CYBER PLAYER"
                       FontFamily="Impact"
                       Foreground="#00FF66"
                       FontSize="24"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <Button Content="[ CARGAR CARPETA ]" 
                    Click="BtnCargarCarpeta_Click"
                    Background="Transparent" 
                    Foreground="#FF007F" 
                    BorderBrush="Transparent"
                    FontFamily="Impact" 
                    FontSize="12" 
                    Margin="20,0,0,0" 
                    Cursor="Hand"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="15,5,15,5">
            <Button Name="BtnVolver" Content="[ ⌂ VOLVER ]" Click="BtnVolver_Click" Background="Black" Foreground="#FF00A8" BorderBrush="Transparent" FontFamily="Impact" Margin="0,0,15,0"/>
            <Button x:Name="BtnVistaTodas" Content="[ TODAS ]" Click="BtnVistaTodas_Click" Background="Transparent" Foreground="#00FF66" BorderThickness="0" FontFamily="Impact" FontSize="14" Margin="0,0,15,0" Cursor="Hand"/>
            <Button x:Name="BtnVistaArtistas" Content="[ ARTISTAS ]" Click="BtnVistaArtistas_Click" Background="Transparent" Foreground="White" BorderThickness="0" FontFamily="Impact" FontSize="14" Margin="0,0,15,0" Cursor="Hand"/>
            <Button x:Name="BtnVistaAlbumes" Content="[ ÁLBUMES ]" Click="BtnVistaAlbumes_Click" Background="Transparent" Foreground="White" BorderThickness="0" FontFamily="Impact" FontSize="14" Margin="0,0,15,0" Cursor="Hand"/>
        </StackPanel>

        <Grid Grid.Row="2" Margin="15,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition>
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=VentanaPrincipal, Path=WindowState}" Value="Maximized">
                                    <Setter Property="Width" Value="1.2*"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
            </Grid.ColumnDefinitions>

            <ListBox x:Name="ListaCanciones" 
                     Grid.Column="0"
                     MouseDoubleClick="ListaCanciones_MouseDoubleClick" 
                     SelectionChanged="ListaCanciones_SelectionChanged"
                     Background="#121212" 
                     BorderBrush="#00FF66" 
                     BorderThickness="1" 
                     FontSize="14" 
                     Foreground="#00FF66" 
                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>

            <Border x:Name="PanelDetalleLateral" 
                    Grid.Column="1" 
                    Margin="15,0,0,0" 
                    BorderBrush="#00FF66" 
                    BorderThickness="1" 
                    Background="#121212">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=VentanaPrincipal, Path=WindowState}" Value="Maximized">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border BorderBrush="#FF00A8" BorderThickness="2" CornerRadius="4" MaxHeight="300" MaxWidth="300">
                            <Image x:Name="ImgCaratula" Stretch="UniformToFill" />
                        </Border>

                        <Button Content="[ EDIT ]" 
                                Click="BtnEditarMetadatos_Click"
                                Width="60" Height="24"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,8,8,0"
                                Background="#121212" Foreground="#FF00A8" 
                                BorderBrush="#FF00A8" BorderThickness="1"
                                FontFamily="Consolas" FontSize="10" FontWeight="Bold" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FF00A8"/>
                                            <Setter Property="Foreground" Value="Black"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>

                    <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,15,0,0" HorizontalAlignment="Center">
                        <TextBlock x:Name="TxtTituloActual" 
                                   Text="SISTEMA EN ESPERA..." 
                                   FontFamily="Impact" 
                                   FontSize="22" 
                                   Foreground="#00FF66" 
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="320"/>

                        <TextBlock x:Name="TxtArtistaActual" 
                                   Text="Carga una pista para iniciar" 
                                   FontFamily="Impact" 
                                   FontSize="14" 
                                   Foreground="#888" 
                                   Margin="0,5,0,0"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="320"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <UniformGrid x:Name="PanelVisualizador" Grid.Row="3" Rows="1" Columns="8" Height="60" VerticalAlignment="Bottom" Margin="30,0,30,15">
            <Grid Margin="3,0" VerticalAlignment="Bottom" Height="60">
                <Rectangle x:Name="Barra0" Fill="#00FF66" VerticalAlignment="Bottom" Height="2">
                    <Rectangle.Effect>
                        <DropShadowEffect Color="#00FF66" BlurRadius="12" ShadowDepth="0" Opacity="0.8"/>
                    </Rectangle.Effect>
                </Rectangle>
                <Rectangle x:Name="Pico0" Fill="#FF007F" Height="2" VerticalAlignment="Bottom" Margin="0,0,0,0">
                    <Rectangle.Effect>
                        <DropShadowEffect Color="#FF007F" BlurRadius="15" ShadowDepth="0" Opacity="0.9"/>
                    </Rectangle.Effect>
                </Rectangle>
            </Grid>

            <Grid Margin="3,0" VerticalAlignment="Bottom" Height="60">
                <Rectangle x:Name="Barra1" Fill="#00FF66" VerticalAlignment="Bottom" Height="2">
                    <Rectangle.Effect>
                        <DropShadowEffect Color="#00FF66" BlurRadius="12" ShadowDepth="0" Opacity="0.8"/>
                    </Rectangle.Effect>
                </Rectangle>
                <Rectangle x:Name="Pico1" Fill="#FF007F" Height="2" VerticalAlignment="Bottom" Margin="0,0,0,0">
                    <Rectangle.Effect>
                        <DropShadowEffect Color="#FF007F" BlurRadius="15" ShadowDepth="0" Opacity="0.9"/>
                    </Rectangle.Effect>
                </Rectangle>
            </Grid>

            <Grid Margin="3,0" VerticalAlignment="Bottom" Height="60">
                <Rectangle x:Name="Barra2" Fill="#00FF66" VerticalAlignment="Bottom" Height="2">
                    <Rectangle.Effect>
                        <DropShadowEffect Color="#00FF66" BlurRadius="12" ShadowDepth="0" Opacity="0.8"/>
                    </Rectangle.Effect>
                </Rectangle>
                <Rectangle x:Name="Pico2" Fill="#FF007F" Height="2" VerticalAlignment="Bottom" Margin="0,0,0,0">
                    <Rectangle.Effect>
                        <DropShadowEffect Color="#FF007F" BlurRadius="15" ShadowDepth="0" Opacity="0.9"/>
                    </Rectangle.Effect>
                </Rectangle>
            </Grid>

            <Grid Margin="3,0" VerticalAlignment="Bottom" Height="60">
                <Rectangle x:Name="Barra3" Fill="#00FF66" VerticalAlignment="Bottom" Height="2">
                    <Rectangle.Effect>
                        <DropShadowEffect Color="#7F00FF" BlurRadius="12" ShadowDepth="0" Opacity="0.8"/>
                    </Rectangle.Effect>
                </Rectangle>
                <Rectangle x:Name="Pico3" Fill="#FF007F" Height="2" VerticalAlignment="Bottom" Margin="0,0,0,0">
                    <Rectangle.Effect>
                        <DropShadowEffect Color="#FF007F" BlurRadius="15" ShadowDepth="0" Opacity="0.9"/>
                    </Rectangle.Effect>
                </Rectangle>
            </Grid>

            <Grid Margin="3,0" VerticalAlignment="Bottom" Height="60">
                <Rectangle x:Name="Barra4" Fill="#00FF66" VerticalAlignment="Bottom" Height="2">
                    <Rectangle.Effect>
                        <DropShadowEffect Color="#7F00FF" BlurRadius="12" ShadowDepth="0" Opacity="0.8"/>
                    </Rectangle.Effect>
                </Rectangle>
                <Rectangle x:Name="Pico4" Fill="#FF007F" Height="2" VerticalAlignment="Bottom" Margin="0,0,0,0">
                    <Rectangle.Effect>
                        <DropShadowEffect Color="#FF007F" BlurRadius="15" ShadowDepth="0" Opacity="0.9"/>
                    </Rectangle.Effect>
                </Rectangle>
            </Grid>

            <Grid Margin="3,0" VerticalAlignment="Bottom" Height="60">
                <Rectangle x:Name="Barra5" Fill="#00FF66" VerticalAlignment="Bottom" Height="2">
                    <Rectangle.Effect>
                        <DropShadowEffect Color="#FF007F" BlurRadius="12" ShadowDepth="0" Opacity="0.8"/>
                    </Rectangle.Effect>
                </Rectangle>
                <Rectangle x:Name="Pico5" Fill="#FF007F" Height="2" VerticalAlignment="Bottom" Margin="0,0,0,0">
                    <Rectangle.Effect>
                        <DropShadowEffect Color="#FF007F" BlurRadius="15" ShadowDepth="0" Opacity="0.9"/>
                    </Rectangle.Effect>
                </Rectangle>
            </Grid>

            <Grid Margin="3,0" VerticalAlignment="Bottom" Height="60">
                <Rectangle x:Name="Barra6" Fill="#00FF66" VerticalAlignment="Bottom" Height="2">
                    <Rectangle.Effect>
                        <DropShadowEffect Color="#FF007F" BlurRadius="12" ShadowDepth="0" Opacity="0.8"/>
                    </Rectangle.Effect>
                </Rectangle>
                <Rectangle x:Name="Pico6" Fill="#FF007F" Height="2" VerticalAlignment="Bottom" Margin="0,0,0,0">
                    <Rectangle.Effect>
                        <DropShadowEffect Color="#FF007F" BlurRadius="15" ShadowDepth="0" Opacity="0.9"/>
                    </Rectangle.Effect>
                </Rectangle>
            </Grid>

            <Grid Margin="3,0" VerticalAlignment="Bottom" Height="60">
                <Rectangle x:Name="Barra7" Fill="#00FF66" VerticalAlignment="Bottom" Height="2">
                    <Rectangle.Effect>
                        <DropShadowEffect Color="#FF007F" BlurRadius="12" ShadowDepth="0" Opacity="0.8"/>
                    </Rectangle.Effect>
                </Rectangle>
                <Rectangle x:Name="Pico7" Fill="#FF007F" Height="2" VerticalAlignment="Bottom" Margin="0,0,0,0">
                    <Rectangle.Effect>
                        <DropShadowEffect Color="#FF007F" BlurRadius="15" ShadowDepth="0" Opacity="0.9"/>
                    </Rectangle.Effect>
                </Rectangle>
            </Grid>
        </UniformGrid>

        <Grid Grid.Row="4" Margin="10,10,10,20" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.8*"/>
                <ColumnDefinition Width="4.9*"/>
                <ColumnDefinition Width="2.3*"/>
            </Grid.ColumnDefinitions>

            <StackPanel x:Name="PanelInfoInferior" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=VentanaPrincipal, Path=WindowState}" Value="Maximized">
                                <Setter Property="Visibility" Value="Hidden"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <Border BorderBrush="#FF00A8" BorderThickness="1" Width="50" Height="50" Background="#111">
                    <Image Source="{Binding ElementName=ImgCaratula, Path=Source}" Stretch="UniformToFill" />
                </Border>

                <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="10,0,5,0">
                    <TextBlock Text="{Binding ElementName=TxtTituloActual, Path=Text}" 
                               FontFamily="Impact" 
                               FontSize="13" 
                               Foreground="#00FF66" 
                               MaxWidth="110" 
                               TextTrimming="CharacterEllipsis"/>

                    <TextBlock Text="{Binding ElementName=TxtArtistaActual, Path=Text}" 
                               FontFamily="Impact" 
                               FontSize="10" 
                               Foreground="#888" 
                               Margin="0,2,0,0"
                               MaxWidth="110" 
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <Button Content="[ EDIT ]" 
                        Click="BtnEditarMetadatos_Click"
                        Width="48" Height="22"
                        Margin="5,0,0,0"
                        Background="Transparent" Foreground="#FF007F" 
                        BorderBrush="#FF007F" BorderThickness="1"
                        FontFamily="Consolas" FontSize="9" FontWeight="Bold" Cursor="Hand"
                        VerticalAlignment="Center">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FF007F"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="5,0">
                <Grid Margin="0,0,0,8" HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="TxtTiempoActual" 
                               Grid.Column="0" 
                               Text="00:00" 
                               Foreground="#00FF66" 
                               FontFamily="Impact" 
                               FontSize="11" 
                               VerticalAlignment="Center" 
                               Margin="0,0,8,0"/>

                    <Slider x:Name="SliderProgreso" 
                            Grid.Column="1"
                            Minimum="0" 
                            Maximum="100" 
                            Value="0" 
                            IsMoveToPointEnabled="True"
                            ValueChanged="SliderProgreso_ValueChanged"
                            VerticalAlignment="Center"
                            Padding="0,6"/>

                    <TextBlock x:Name="TxtTiempoTotal" 
                               Grid.Column="2" 
                               Text="00:00" 
                               Foreground="#FF007F" 
                               FontFamily="Impact" 
                               FontSize="11" 
                               VerticalAlignment="Center" 
                               Margin="8,0,0,0"/>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="BtnAleatorio" Content="SHUFFLE [OFF]" Click="BtnAleatorio_Click" Background="Transparent" Foreground="#FFFFFF" BorderBrush="#FFFFFF" BorderThickness="1" Padding="6,4" Margin="2,0" FontFamily="Impact" FontSize="10" Cursor="Hand"/>
                    <Button Content="⏮ PREV" Click="BtnAnterior_Click" Background="Transparent" Foreground="#FFFFFF" BorderBrush="#FFFFFF" BorderThickness="1" Padding="8,4" Margin="2,0" FontFamily="Impact" FontSize="10" Cursor="Hand"/>
                    <Button x:Name="BtnPlayPause" Content="▶ PLAY" Click="BtnPlayPause_Click" Background="Transparent" Foreground="#00FF66" BorderBrush="#00FF66" BorderThickness="1" Padding="12,4" Margin="2,0" FontFamily="Impact" FontSize="11" Cursor="Hand"/>
                    <Button Content="■ STOP" Click="BtnStop_Click" Background="Transparent" Foreground="#FFFFFF" BorderBrush="#FFFFFF" BorderThickness="1" Padding="12,4" Margin="2,0" FontFamily="Impact" FontSize="11" Cursor="Hand"/>
                    <Button Content="NEXT ⏭" Click="BtnSiguiente_Click" Background="Transparent" Foreground="#FFFFFF" BorderBrush="#FFFFFF" BorderThickness="1" Padding="8,4" Margin="2,0" FontFamily="Impact" FontSize="10" Cursor="Hand"/>
                    <Button x:Name="BtnRepetir" Content="REPEAT [OFF]" Click="BtnRepetir_Click" Background="Transparent" Foreground="#FFFFFF" BorderBrush="#FFFFFF" BorderThickness="1" Padding="6,4" Margin="2,0" FontFamily="Impact" FontSize="10" Cursor="Hand"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="VOL: " Foreground="#FFFFFF" FontFamily="Impact" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <Slider x:Name="SliderVolumen" 
                        Width="90" 
                        Minimum="0" 
                        Maximum="1" 
                        Value="0.5" 
                        IsMoveToPointEnabled="True"
                        ValueChanged="SliderVolumen_ValueChanged"
                        VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>