<Window x:Class="CyberPlayer.EditorMetadatos"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberPlayer"
        mc:Ignorable="d"
        Title="EditorMetadatos" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Column="0" Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border BorderBrush="#FF007F" BorderThickness="2" CornerRadius="5" Width="150" Height="150" Background="#1E1E1E">
                <Image x:Name="ImgCover" Stretch="UniformToFill"/>
            </Border>
            <Button x:Name="BtnBuscarCover" Content="Buscar Online 🌐" Margin="0,15,0,5" Click="BtnBuscarCover_Click" Background="#212121" Foreground="White" BorderBrush="#00FF7F"/>
            <Button x:Name="BtnCargarLocal" Content="Subir Local 📁" Click="BtnCargarLocal_Click" Background="#212121" Foreground="White" BorderBrush="#00FF7F"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Grid.Row="0" Margin="20,0,0,0" VerticalAlignment="Center">
            <TextBlock Text="TITULO DE CANCIÓN" Foreground="#00FF7F" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtTitulo" Background="#1A1A1A" Foreground="White" BorderBrush="#FF007F" Padding="5" Margin="0,0,0,15"/>

            <TextBlock Text="ARTISTA" Foreground="#00FF7F" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtArtista" Background="#1A1A1A" Foreground="White" BorderBrush="#FF007F" Padding="5" Margin="0,0,0,15"/>

            <TextBlock Text="ÁLBUM" Foreground="#00FF7F" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtAlbum" Background="#1A1A1A" Foreground="White" BorderBrush="#FF007F" Padding="5" Margin="0,0,0,15"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="BtnCancelar" Content="Cancelar" Width="100" Height="35" Click="BtnCancelar_Click" Margin="0,0,10,0" Background="#333" Foreground="White"/>
            <Button x:Name="BtnGuardar" Content="Guardar Cambios" Width="130" Height="35" Click="BtnGuardar_Click" Background="#00FF7F" Foreground="Black" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
